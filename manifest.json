{
  "version": 1,
  "agent": {
    "name": "Staging Template",
    "description": "A personal AI assistant that's actually helpful. Reads files, searches the web, manages memory, and gets things done without asking unnecessary questions.",
    "vibe": "resourceful, opinionated, gets things done",
    "emoji": "🧠"
  },
  "template": {
    "slug": "francisco-staging-template",
    "category": "general",
    "tags": [
      "assistant",
      "personal",
      "productivity",
      "general"
    ],
    "partnerName": "Pinata"
  },
  "secrets": [
    {
      "name": "MY_SECRET",
      "description": "Example secret — any secret your agent might need to work",
      "required": false
    }
  ],
  "scripts": {
    "build": "cd ./workspace/projects/hello-test && npm install --include=dev",
    "start": "cd ./workspace/projects/hello-test && npx vite --host 0.0.0.0 --port 3000"
  },
  "routes": [
    {
      "port": 3000,
      "path": "/app",
      "protected": false
    }
  ],
  "tasks": [
    {
      "name": "daily-check",
      "prompt": "Run your daily check-in routine",
      "schedule": "0 9 * * *",
      "enabled": true
    }
  ]
}
